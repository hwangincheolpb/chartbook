# tool/.env.example — 차트 관리 툴 환경변수 샘플
# 실제 사용: cp .env.example .env 후 값 채우기. .env 는 절대 커밋 금지(.gitignore).

# FRED API 키 (선택) — 없으면 FRED 소스가 "키 필요"로 비활성 표시.
# 발급: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# 한국은행 ECOS API 키 (선택) — 없으면 ECOS 소스가 "키 필요"로 비활성 표시.
# 발급: https://ecos.bok.or.kr/api/  (OpenAPI 인증키 신청)
ECOS_API_KEY=
